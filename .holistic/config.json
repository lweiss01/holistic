{
  "version": 1,
  "autoInferSessions": true,
  "autoSync": false,
  "sync": {
    "strategy": "state-branch",
    "remote": "origin",
    "stateBranch": "holistic/state",
    "syncOnCheckpoint": false,
    "syncOnHandoff": false,
    "postHandoffPush": false,
    "restoreOnStartup": false,
    "trackedPaths": [
      "HOLISTIC.md",
      "AGENTS.md",
      "CLAUDE.md",
      "GEMINI.md",
      "HISTORY.md",
      ".holistic"
    ]
  },
  "daemon": {
    "intervalSeconds": 30,
    "agent": "unknown"
  }
}
